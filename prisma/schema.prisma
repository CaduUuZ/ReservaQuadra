// Schema do Prisma — define os models que viram tabelas no Postgres.
// Doc: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Tipo de conta: quem joga vs quem é dono de quadra.
enum Role {
  JOGADOR
  EMPRESA
}

// Usuário que faz reservas.
model User {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  email     String          @unique
  password  String // hash bcrypt — NUNCA a senha em texto puro
  role      Role            @default(JOGADOR)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings  Booking[] // reservas das quais é DONO
  waitlist  WaitlistEntry[]
  participations Participant[] // jogos dos quais participa (como usuário cadastrado)
  ownedResources Resource[] // quadras que esta EMPRESA possui

  @@map("users")
}

// Esportes que uma quadra pode aceitar / um jogo pode ser.
enum Sport {
  FUTEBOL
  VOLEI
  TENIS
  BEACH_TENNIS
  FUTEVOLEI
  BASQUETE
}

// Tipo de piso da quadra.
enum Surface {
  AREIA
  SAIBRO
  SINTETICO
  CIMENTO
  GRAMA
}

// A quadra (o recurso que é reservado).
model Resource {
  id           String          @id @default(uuid()) @db.Uuid
  name         String
  sports       Sport[] // esportes que a quadra aceita (array de enum no Postgres)
  surface      Surface         @default(SINTETICO) // tipo de piso
  pricePerHour Int? // preço por hora em CENTAVOS (ex: 8000 = R$ 80,00); informativo
  // Empresa dona da quadra (null = quadra "do sistema", sem dono).
  owner        User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId      String?         @map("owner_id") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings     Booking[]
  waitlist     WaitlistEntry[]

  @@index([ownerId])
  @@map("resources")
}

// Situação de uma entrada na fila de espera.
enum WaitlistStatus {
  WAITING // aguardando uma vaga
  PROMOTED // virou reserva (alguém cancelou e esta entrada foi promovida)
  CANCELLED // o usuário saiu da fila
}

// Fila de espera: usuário que quer um horário já ocupado. Quando a reserva
// daquele horário é cancelada, o primeiro WAITING (mais antigo) é promovido.
model WaitlistEntry {
  id         String         @id @default(uuid()) @db.Uuid
  resource   Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId String         @map("resource_id") @db.Uuid
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String         @map("user_id") @db.Uuid
  startsAt   DateTime       @map("starts_at") @db.Timestamptz(6)
  endsAt     DateTime       @map("ends_at") @db.Timestamptz(6)
  status     WaitlistStatus @default(WAITING)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  // Índice pensado pra busca do "próximo da fila": mesma quadra+horário, status WAITING.
  @@index([resourceId, startsAt, endsAt, status])
  @@map("waitlist_entries")
}

// A reserva: uma quadra ocupada por um usuário em um intervalo de tempo.
model Booking {
  id         String   @id @default(uuid()) @db.Uuid
  // Relação com a quadra. onDelete: Cascade = se a quadra some, as reservas dela somem junto.
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId String   @map("resource_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id") @db.Uuid
  // Guardamos início e fim como timestamptz. O "intervalo" (range) que impede
  // sobreposição é montado a partir destas duas colunas na constraint EXCLUDE
  // (adicionada manualmente na migration). Por isso o @map importa: o SQL da
  // constraint referencia os nomes reais das colunas (starts_at, ends_at, resource_id).
  startsAt   DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt     DateTime @map("ends_at") @db.Timestamptz(6)
  sport      Sport? // esporte escolhido pra este jogo (dentre os que a quadra aceita)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // O "user/userId" acima é o DONO do jogo. Os jogadores (incl. o dono) ficam aqui.
  participants Participant[]

  @@index([resourceId])
  @@map("bookings")
}

// Um participante de um jogo (reserva). É um usuário cadastrado (userId) OU um
// convidado sem conta (guestName). A CHECK constraint na migration garante que
// exatamente um dos dois esteja preenchido.
model Participant {
  id        String   @id @default(uuid()) @db.Uuid
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String   @map("booking_id") @db.Uuid
  // Se for um usuário cadastrado, aponta pra ele; se sair, vira convidado anônimo.
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?  @map("user_id") @db.Uuid
  guestName String?  @map("guest_name") // preenchido quando é convidado (sem conta)
  team      Int? // usado na Fase 10 (separação de times); null = sem time ainda
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([bookingId])
  @@map("participants")
}
